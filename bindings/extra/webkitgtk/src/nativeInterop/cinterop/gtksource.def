headers = webkit2/webkit2.h
package = org.gtkkn.native.gtksource
headerFilter = "webkit2/*"

# pkg-config --cflags gtksourceview-5
compilerOpts.linux = \
    -I/usr/include \
    -I/usr/include/webkitgtk-4.1 \
    -I/usr/include/glib-2.0 \
    -I/usr/include/gtk-4.0 \
    -I/usr/include/gtk-3.0 \
    -I/usr/include/pango-1.0 \
    -I/usr/include/harfbuzz \
    -I/usr/include/freetype2 \
    -I/usr/include/libpng16 \
    -I/usr/include/libmount \
    -I/usr/include/blkid \
    -I/usr/include/fribidi \
    -I/usr/include/cairo \
    -I/usr/include/pixman-1 \
    -I/usr/include/gdk-pixbuf-2.0 \
    -I/usr/include/x86_64-linux-gnu \
    -I/usr/include/webp \
    -I/usr/include/gio-unix-2.0 \
    -I/usr/include/atk-1.0 \
    -I/usr/include/at-spi2-atk/2.0 \
    -I/usr/include/at-spi-2.0 \
    -I/usr/include/dbus-1.0 \
    -I/usr/include/libsoup-3.0 \
    -I/usr/include/sysprof-4 \
    -pthread \

compilerOpts.linux_x64 = \
    -I/usr/lib64/glib-2.0/include \
    -I/usr/lib64/graphene-1.0/include \
    -I/usr/lib/x86_64-linux-gnu/glib-2.0/include \
    -I/usr/lib/x86_64-linux-gnu/dbus-1.0/include

# pkg-config --libs gtksourceview-5
linkerOpts.linux = \
    -L/usr/local/lib \
    -lwebkit2gtk-4.1 \
    -lgtk-3 \
    -lgdk-3 \
    -lz \
    -lpangocairo-1.0 \
    -lpango-1.0 \
    -lharfbuzz \
    -latk-1.0 \
    -lcairo-gobject \
    -lcairo \
    -lgdk_pixbuf-2.0 \
    -lsoup-3.0 \
    -Wl,--export-dynamic \
    -lgmodule-2.0 \
    -pthread \
    -lglib-2.0 \
    -lgio-2.0 \
    -ljavascriptcoregtk-4.1 \
    -lgobject-2.0 \
    -lglib-2.0

linkerOpts.linux_x64 = \
    -L/usr/lib/x86_64-linux-gnu \
    -L/usr/lib64


